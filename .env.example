# === WorldView Environment Variables ===

# Cesium Ion access token (required for terrain/imagery)
# Get one at https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=

# Google Maps 3D Tiles API key (optional — enables photorealistic 3D tiles)
# Get one at https://console.cloud.google.com (enable Map Tiles API)
VITE_GOOGLE_MAPS_API_KEY=

# OpenWeatherMap API key (optional — enables weather overlay)
# Get one at https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=

# HQ / base locations (optional — highlighted in navigation panel)
# Format: name|lat|lon|alt|city  — separate multiple with ;
# Default: Kärnten Funkt HQ in Villach
# Example with multiple:
# VITE_HQ_LOCATIONS="Kärnten Funkt HQ|46.6103|13.8558|5000|Villach;Berlin Office|52.52|13.405|8000|Berlin"
VITE_HQ_LOCATIONS=
